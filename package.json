{
  "name": "loop-station",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "loop-station": "./bin/loop-station"
  },
  "scripts": {
    "generate:presets": "node skills/loop-station/presets/generate.js",
    "test": "node --test --test-concurrency=1 test/*.test.js skills/loop-station/assets/harness-template/test/*.test.js skills/loop-station/assets/harness-template/test/*.integration.js",
    "test:ci": "node --test --test-concurrency=1 test/*.test.js skills/loop-station/assets/harness-template/test/*.test.js",
    "validate:template": "node skills/loop-station/assets/harness-template/bin/station validate",
    "validate:template:ci": "node skills/loop-station/assets/harness-template/bin/station validate --skip-tools",
    "verify:ci": "npm run test:ci && npm run validate:template:ci",
    "verify:full": "npm test && npm run validate:template",
    "hooks:install": "git config core.hooksPath .githooks",
    "smoke:template": "node skills/loop-station/assets/harness-template/bin/station smoke-run-one"
  },
  "engines": {
    "node": ">=20"
  }
}
